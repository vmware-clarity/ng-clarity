{
  "$schema": "./figma-tokens.config.schema.json",

  "_comment": "Order of collections building is important. First GLOBAL COLORS and SPACE, then DENSITY, then LAYOUT, then EVERYTHING else.",
  "collections": [
    {
      "name": "CDS Global Colors",
      "hiddenFromPublishing": true,
      "filter": { "include": ["--cds-global-color-"] },
      "modes": [{ "name": "Value", "source": "root" }]
    },
    {
      "name": "CDS Global Space",
      "hiddenFromPublishing": true,
      "filter": { "include": ["--cds-global-space-", "--cds-alias-object-border-width-"] },
      "modes": [{ "name": "Value", "source": "root" }]
    },
    {
      "_comment": "Density scale tokens referenced by CDS Spacing aliases. Must be processed before CDS Spacing so var(--clr-base-*) references in typography tokens resolve as VARIABLE_ALIAS in idMap.",
      "name": "CLR Density",
      "hiddenFromPublishing": true,
      "filter": { "include": ["--clr-base-"] },
      "modes": [
        { "name": "Regular", "source": "root" },
        { "name": "Compact", "source": "compact" }
      ]
    },
    {
      "name": "CDS Global Layout",
      "hiddenFromPublishing": true,
      "filter": { "include": ["--cds-global-layout-"] },
      "modes": [{ "name": "Value", "source": "root" }]
    },
    {
      "_comment": "Semantic colour aliases — full-namespace colour groups (status, viz, utility) plus the colour-bearing sub-tokens inside the object and typography namespaces.",
      "name": "CDS Theme",
      "hiddenFromPublishing": true,
      "filter": {
        "include": [
          "--cds-alias-status-",
          "--cds-alias-viz-",
          "--cds-alias-utility-",
          "--cds-alias-object-interaction-background",
          "--cds-alias-object-interaction-border-color",
          "--cds-alias-object-interaction-color",
          "--cds-alias-object-interaction-info-",
          "--cds-alias-object-interaction-success-",
          "--cds-alias-object-interaction-warning-",
          "--cds-alias-object-interaction-danger-",
          "--cds-alias-object-interaction-neutral-",
          "--cds-alias-object-interaction-inverse-",
          "--cds-alias-object-app-",
          "--cds-alias-object-overlay-",
          "--cds-alias-object-border-color",
          "--cds-alias-object-container-",
          "--cds-alias-object-opacity-",
          "--cds-alias-typography-color-",
          "--cds-alias-typography-link-",
          "--cds-alias-typography-info-",
          "--cds-alias-typography-success-",
          "--cds-alias-typography-warning-",
          "--cds-alias-typography-danger-",
          "--cds-alias-typography-neutral-",
          "--cds-alias-typography-disabled"
        ]
      },
      "modes": [
        { "name": "Light", "source": "root" },
        { "name": "Dark", "source": "dark" }
      ]
    },
    {
      "_comment": "Structural and sizing aliases for typography metrics. The exclude list mirrors CDS Theme's colour sub-prefixes so the two collections are mutually exclusive. CLR Density must appear before this collection so typography var(--clr-base-*) aliases resolve correctly.",
      "name": "CDS Typography",
      "hiddenFromPublishing": true,
      "filter": {
        "include": ["--cds-alias-typography-"],
        "exclude": [
          "--cds-alias-typography-color-",
          "--cds-alias-typography-link-",
          "--cds-alias-typography-info-",
          "--cds-alias-typography-success-",
          "--cds-alias-typography-warning-",
          "--cds-alias-typography-danger-",
          "--cds-alias-typography-neutral-",
          "--cds-alias-typography-disabled"
        ]
      },
      "modes": [{ "name": "Value", "source": "root" }]
    },
    {
      "_comment": "Structural and sizing aliases — border-radius, border-width, shadow, interaction geometry. The exclude list mirrors CDS Theme's colour sub-prefixes so the two collections are mutually exclusive. CLR Density must appear before this collection so typography var(--clr-base-*) aliases resolve correctly.",
      "name": "CDS Spacing",
      "hiddenFromPublishing": true,
      "filter": {
        "include": ["--cds-alias-object-"],
        "exclude": [
          "--cds-alias-object-border-width-",
          "--cds-alias-object-interaction-background",
          "--cds-alias-object-interaction-border-color",
          "--cds-alias-object-interaction-color",
          "--cds-alias-object-interaction-info-",
          "--cds-alias-object-interaction-success-",
          "--cds-alias-object-interaction-warning-",
          "--cds-alias-object-interaction-danger-",
          "--cds-alias-object-interaction-neutral-",
          "--cds-alias-object-interaction-inverse-",
          "--cds-alias-object-app-",
          "--cds-alias-object-overlay-",
          "--cds-alias-object-border-color",
          "--cds-alias-object-container-",
          "--cds-alias-object-opacity-"
        ]
      },
      "modes": [{ "name": "Value", "source": "root" }]
    },
    {
      "_comment": "Friendly-named alias variables. Each entry in the top-level humanReadable map creates a VARIABLE_ALIAS that points to the corresponding semantic token, giving designers clean display names while preserving the live alias chain.",
      "name": "Colors",
      "hiddenFromPublishing": false,
      "humanReadable": {
        "Primary/Body text": "--cds-alias-typography-color-400",
        "Primary/Body text - Disabled": "--cds-alias-typography-disabled",
        "Primary/Link": "--cds-alias-typography-link-color",
        "Container/App Background": "--cds-alias-object-app-background",
        "Container/Container Background": "--cds-alias-object-container-background",
        "Container/Container Background (Tinted)": "--cds-alias-object-container-background-tint",
        "Container/Divider Border": "--cds-alias-object-container-border-color",
        "Container/Modal Overlay": "--cds-alias-object-overlay-backdrop-background",
        "Interactive Background/Default": "--cds-alias-object-interaction-background",
        "Interactive Background/Hover": "--cds-alias-object-interaction-background-hover",
        "Interactive Background/Active": "--cds-alias-object-interaction-background-active",
        "Interactive Background/Selected": "--cds-alias-object-interaction-background-selected",
        "Interactive Background/Selected + Hover": "--cds-alias-object-interaction-background-selected-hover",
        "Interactive Background/Selected + Active": "--cds-alias-object-interaction-background-selected-active",
        "Interactive Background/Border": "--cds-alias-object-interaction-border-color",
        "Interactive Text & Icon/Default": "--cds-alias-typography-color-400",
        "Interactive Text & Icon/Placeholder": "--cds-alias-typography-color-200",
        "Interactive Text & Icon/Hover": "--cds-alias-object-interaction-color-hover",
        "Interactive Text & Icon/Active": "--cds-alias-object-interaction-color-active",
        "Interactive Text & Icon/Selected": "--cds-alias-object-interaction-color-selected",
        "Interactive Text & Icon/Selected + Hover": "--cds-alias-object-interaction-color-selected",
        "Interactive Text & Icon/Selected + Active": "--cds-alias-object-interaction-color-selected",
        "Interactive Text & Icon/Disabled": "--cds-alias-typography-disabled",
        "Context Colors/Primary/Default": "--cds-alias-status-info",
        "Context Colors/Primary/Hover": "--cds-alias-object-interaction-info-hover",
        "Context Colors/Primary/Active": "--cds-alias-object-interaction-info-active",
        "Context Colors/Primary/Tint": "--cds-alias-status-info-tint",
        "Context Colors/Success/Default": "--cds-alias-status-success",
        "Context Colors/Success/Hover": "--cds-alias-object-interaction-success-hover",
        "Context Colors/Success/Active": "--cds-alias-object-interaction-success-active",
        "Context Colors/Success/Tint": "--cds-alias-status-success-tint",
        "Context Colors/Warning/Default": "--cds-alias-status-warning",
        "Context Colors/Warning/Hover": "--cds-alias-object-interaction-warning-hover",
        "Context Colors/Warning/Active": "--cds-alias-object-interaction-warning-active",
        "Context Colors/Warning/Tint": "--cds-alias-status-warning-tint",
        "Context Colors/Error/Default": "--cds-alias-status-danger",
        "Context Colors/Error/Hover": "--cds-alias-object-interaction-danger-hover",
        "Context Colors/Error/Active": "--cds-alias-object-interaction-danger-active",
        "Context Colors/Error/Tint": "--cds-alias-status-danger-tint",
        "Context Colors/Neutral/Default": "--cds-alias-status-neutral",
        "Context Colors/Neutral/Hover": "--cds-alias-object-interaction-neutral-hover",
        "Context Colors/Neutral/Active": "--cds-alias-object-interaction-neutral-active",
        "Context Colors/Neutral/Tint": "--cds-alias-status-neutral-tint"
      },
      "filter": { "include": [] },
      "modes": [{ "name": "Value", "source": "root" }]
    },
    {
      "_comment": "Friendly-named alias variables. Each entry in the top-level humanReadable map creates a VARIABLE_ALIAS that points to the corresponding semantic token, giving designers clean display names while preserving the live alias chain.",
      "name": "Spacings",
      "hiddenFromPublishing": false,
      "humanReadable": {
        "0": "--clr-base-layout-space-0",
        "1": "--clr-base-layout-space-4xs",
        "2": "--clr-base-layout-space-3xs",
        "4": "--clr-base-layout-space-2xs",
        "8": "--clr-base-layout-space-xs",
        "12": "--clr-base-layout-space-s",
        "16": "--clr-base-layout-space-m",
        "24": "--clr-base-layout-space-l",
        "32": "--clr-base-layout-space-xl",
        "40": "--clr-base-layout-space-2xl",
        "48": "--clr-base-layout-space-3xl",
        "64": "--clr-base-layout-space-4xl",
        "96": "--clr-base-layout-space-5xl"
      },
      "filter": { "include": [] },
      "modes": [{ "name": "Value", "source": "root" }]
    }
  ],

  "exclusions": {
    "_comment": "Tokens excluded from publishing. Patterns are lowercase substring matches. Exact names are matched case-insensitively.",
    "patterns": ["deprecated", "internal", "-outline"],
    "exact": [
      "--cds-global-layout-grid-cols",
      "--cds-alias-object-skeleton-loading-gradient",
      "--cds-alias-typography-top-gap-height",
      "--cds-alias-typography-monospace-font-family",
      "--cds-alias-typography-ascender-height",
      "--cds-alias-typography-x-height"
    ]
  },

  "scopeRules": [
    {
      "_comment": "Global tokens have no scopes",
      "pattern": "--cds-global-*",
      "scopes": []
    },
    {
      "_comment": "Font family tokens",
      "pattern": "*font-family*",
      "scopes": ["FONT_FAMILY"]
    },
    {
      "_comment": "Font size tokens",
      "pattern": "*font-size*",
      "scopes": ["FONT_SIZE"]
    },
    {
      "_comment": "Font weight tokens",
      "pattern": "*font-weight*",
      "scopes": ["FONT_WEIGHT"]
    },
    {
      "_comment": "Line height tokens",
      "pattern": "*line-height*",
      "scopes": ["LINE_HEIGHT"]
    },
    {
      "_comment": "Letter spacing tokens",
      "pattern": "*letter-spacing*",
      "scopes": ["LETTER_SPACING"]
    },
    {
      "_comment": "Paragraph spacing tokens",
      "pattern": "*paragraph-spacing*",
      "scopes": ["PARAGRAPH_SPACING"]
    },
    {
      "_comment": "Typography colour tokens — text, link, semantic states, and disabled. Pattern uses regex alternation (| is passed through to RegExp unchanged by the * → .* conversion in token-rules.mjs).",
      "pattern": "--cds-alias-typography-(color-|link-|info-|success-|warning-|danger-|neutral-|disabled)*",
      "scopes": ["TEXT_FILL"]
    },
    {
      "_comment": "Typography catch-all — structural tokens (font metrics, letter-spacing, line-height) not matched by the specific rules above.",
      "pattern": "*typography*",
      "scopes": ["FONT_SIZE", "FONT_WEIGHT", "FONT_FAMILY", "LINE_HEIGHT", "LETTER_SPACING"]
    },
    {
      "_comment": "Border radius tokens",
      "pattern": "*(border-radius|borderradius)*",
      "scopes": ["CORNER_RADIUS"]
    },
    {
      "_comment": "Opacity tokens",
      "pattern": "*opacity*",
      "scopes": ["ALL_FILLS"]
    },
    {
      "_comment": "Gap / spacing tokens used in layouts",
      "pattern": "*-gap*",
      "scopes": ["GAP"]
    },
    {
      "_comment": "Background color tokens",
      "pattern": "*(-background*|-bg)",
      "scopes": ["FRAME_FILL", "SHAPE_FILL"]
    },
    {
      "_comment": "Text / foreground color tokens",
      "pattern": "*-text*",
      "scopes": ["TEXT_FILL"]
    },
    {
      "_comment": "Stroke / border color tokens",
      "pattern": "*(-border-color|-viz-border)*",
      "scopes": ["STROKE_COLOR"]
    },
    {
      "_comment": "Border-specific token names",
      "pattern": "*(-border-width|-stroke)*",
      "scopes": ["STROKE_FLOAT"]
    },
    {
      "_comment": "Width / height dimension tokens",
      "pattern": "*(-width|-height|-base-vertical-offset|-base-horizontal-offset|-base-icon-tooltip|-base-icon-size|-base-spinner-|-base-layout-space)*",
      "scopes": ["WIDTH_HEIGHT"]
    },
    {
      "_comment": "Shadow / effect color tokens",
      "pattern": "*-shadow*",
      "scopes": ["EFFECT_COLOR"]
    },
    {
      "_comment": "Generic color tokens (palette, status colours, etc.)",
      "pattern": "*-color*",
      "scopes": ["ALL_FILLS", "STROKE_COLOR", "EFFECT_COLOR"]
    },
    {
      "_comment": "Global layout spacing tokens",
      "pattern": "--cds-global-layout-space*",
      "scopes": ["GAP", "WIDTH_HEIGHT"]
    }
  ],

  "codeSyntax": {
    "_comment": "Templates for Figma Code Syntax (code context shown to designers). Supports: ${name} (full CSS var name), ${kebab} (name without leading --), ${camel} (camelCase). WEB-only by design: ng-clarity ships CSS custom properties only — there are no published Android/iOS Clarity token packages, so ANDROID/iOS code syntax is intentionally omitted to avoid showing designers references that don't exist.",
    "WEB": "var(${name})"
  }
}
