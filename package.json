{
  "name": "@clr/angular",
  "private": true,
  "engines": {
    "yarn": "please-use-npm",
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "build": "npm-run-all _build:angular _build:addons _build:ui _build:storybook _build:demo _build:website",
    "build:ci": "npm-run-all clean lint build test public-api:check",
    "clean": "rimraf dist",
    "commit": "cz --signoff",
    "lint": "npm-run-all _lint:code _lint:styles _lint:format _lint:format-stories _lint:format-code-examples",
    "lint:fix": "npm-run-all _lint:code:fix _lint:styles:fix _lint:format:fix _lint:format-stories:fix _lint:format-code-examples:fix",
    "lint:changed": "npm-run-all _lint:code:changed _lint:styles:changed _lint:format:changed _lint:format-stories:changed _lint:format-code-examples:changed",
    "lint:changed:fix": "npm-run-all _lint:code:changed:fix _lint:styles:changed:fix _lint:format:changed:fix _lint:format-stories:changed:fix _lint:format-code-examples:changed:fix",
    "prepare": "husky install && patch-package",
    "public-api:check": "node scripts/api-extractor.js",
    "public-api:update": "node scripts/api-extractor.js --local",
    "start": "npm run clean && ng run clr-angular:storybook",
    "start:demo": "npm run clean && ng serve clr-demo",
    "start:website": "npm-run-all prebuild:website --parallel start:website:*",
    "start:website:serve": "ng serve clr-website",
    "start:website:compile-content": "nodemon --watch projects/website/cms-content --watch projects/website/stackblitz-example-template --ext md,json,js,ts,css,scss,html --exec \"npm run prebuild:website:compile-content\"",
    "prebuild:website": "npm-run-all prebuild:website:*",
    "prebuild:website:compile-cms": "babel ./projects/website/src/admin/main.jsx --presets=@babel/preset-react --out-file ./projects/website/src/admin/main.js",
    "prebuild:website:compile-content": "node ./projects/website/scripts/compile-content.js",
    "prebuild:website:generate-versions": "node ./projects/website/scripts/generate-versions.js",
    "test": "npm-run-all _test:angular _test:addons",
    "test:watch": "npm-run-all --parallel _test:angular:watch _test:addons:watch",
    "ts-node": "ts-node --project ./tsconfig-ts-node.json",
    "_test:angular": "ng test clr-angular --configuration=ci",
    "_test:addons": "ng test clr-addons --configuration=ci",
    "_test:angular:watch": "ng test clr-angular",
    "_test:addons:watch": "ng test clr-addons",
    "_build:angular": "ng build clr-angular --configuration production",
    "_build:addons": "ng build clr-addons --configuration production",
    "_build:demo": "ng build clr-demo --configuration production",
    "_build:website": "npm-run-all prebuild:website && ng build clr-website --configuration production",
    "_build:storybook": "ng run clr-angular:build-storybook",
    "_build:ui": "npm-run-all _build:ui:css _build:ui:prefix _build:ui:optimize _build:ui:required-files _build:ui:style-docs",
    "_build:ui:css": "sass ./projects/ui/src:./dist/clr-ui --precision=8 --load-path=node_modules",
    "_build:ui:prefix": "postcss ./dist/clr-ui/clr-ui.css --use autoprefixer --dir ./dist/clr-ui",
    "_build:ui:optimize": "npm-run-all _build:ui:optimize:*",
    "_build:ui:optimize:clr-ui": "csso ./dist/clr-ui/clr-ui.css --output ./dist/clr-ui/clr-ui.min.css --source-map file --no-restructure",
    "_build:ui:style-docs": "node ./scripts/compile-style-docs.js",
    "_build:ui:required-files": "node ./scripts/copy-ui-files.js",
    "_lint:code": "eslint .",
    "_lint:code:fix": "npm run --silent _lint:code -- --fix",
    "_lint:code:changed": "node ./scripts/get-changed-files.js --command \"eslint\"",
    "_lint:code:changed:fix": "node ./scripts/get-changed-files.js --command \"eslint --fix\"",
    "_lint:format": "prettier . --check --log-level warn",
    "_lint:format:fix": "npm run --silent _lint:format -- --write",
    "_lint:format:changed": "node ./scripts/get-changed-files.js --command \"prettier --check --log-level warn --ignore-unknown\" --filter \"**\"",
    "_lint:format:changed:fix": "node ./scripts/get-changed-files.js --command \"prettier --write --log-level warn --ignore-unknown\" --filter \"**\"",
    "_lint:format-stories": "node ./scripts/format-story-templates.js",
    "_lint:format-stories:fix": "node ./scripts/format-story-templates.js --fix",
    "_lint:format-stories:changed": "node ./scripts/get-changed-files.js --command \"node ./scripts/format-story-templates.js\"",
    "_lint:format-stories:changed:fix": "node ./scripts/get-changed-files.js --command \"node ./scripts/format-story-templates.js --fix\"",
    "_lint:styles": "stylelint \"**/*.{css,scss,sass}\" \"**/.*/**/*.{css,scss,sass}\"",
    "_lint:styles:fix": "npm run --silent _lint:styles -- --fix",
    "_lint:styles:changed": "node ./scripts/get-changed-files.js --command \"stylelint\" --filter \"**/*.{css,scss,sass}\"",
    "_lint:styles:changed:fix": "node ./scripts/get-changed-files.js --command \"stylelint --fix\" --filter \"**/*.{css,scss,sass}\"",
    "_lint:format-code-examples": "node ./projects/website/scripts/format-code-examples.js",
    "_lint:format-code-examples:fix": "node ./projects/website/scripts/format-code-examples.js --fix",
    "_lint:format-code-examples:changed": "node ./scripts/get-changed-files.js --command \"node ./projects/website/scripts/format-code-examples.js\"",
    "_lint:format-code-examples:changed:fix": "node ./scripts/get-changed-files.js --command \"node ./projects/website/scripts/format-code-examples.js --fix\""
  },
  "devDependencies": {
    "@amanda-mitchell/semantic-release-npm-multiple": "3.17.0",
    "@angular-devkit/build-angular": "21.1.3",
    "@angular/animations": "21.1.3",
    "@angular/build": "21.1.3",
    "@angular/cdk": "21.1.4",
    "@angular/cli": "21.1.3",
    "@angular/common": "21.2.0",
    "@angular/compiler": "21.1.3",
    "@angular/compiler-cli": "21.1.3",
    "@angular/core": "21.2.0",
    "@angular/elements": "21.1.3",
    "@angular/forms": "21.1.3",
    "@angular/platform-browser": "21.1.3",
    "@angular/platform-browser-dynamic": "21.1.3",
    "@angular/router": "21.1.3",
    "@babel/cli": "7.28.6",
    "@babel/core": "7.29.0",
    "@babel/preset-react": "7.28.5",
    "@compodoc/compodoc": "1.2.1",
    "@eslint/js": "9.39.2",
    "@eslint/json": "1.0.0",
    "@html-eslint/eslint-plugin": "0.55.0",
    "@html-eslint/parser": "0.57.1",
    "@microsoft/api-extractor": "7.56.3",
    "@playwright/test": "1.58.2",
    "@semantic-release/exec": "7.1.0",
    "@stackblitz/sdk": "1.11.0",
    "@storybook/addon-a11y": "10.2.14",
    "@storybook/addon-docs": "10.2.8",
    "@storybook/angular": "10.2.8",
    "@textlint/markdown-to-ast": "15.5.2",
    "@types/jasmine": "6.0.0",
    "@types/node-static": "0.7.12",
    "@types/prismjs": "1.26.6",
    "@typescript-eslint/eslint-plugin": "8.55.0",
    "@typescript-eslint/parser": "8.55.0",
    "autoprefixer": "10.4.24",
    "csso-cli": "4.0.2",
    "domino": "2.1.6",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-decorator-position": "6.0.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jasmine": "4.2.2",
    "eslint-plugin-license-header": "0.9.0",
    "eslint-plugin-ng-clarity-eslint-rules": "file:./eslint-rules",
    "eslint-plugin-storybook": "10.2.8",
    "eslint-plugin-unused-imports": "4.4.1",
    "express": "5.2.1",
    "front-matter": "4.0.2",
    "glob": "13.0.1",
    "globals": "17.3.0",
    "html-minifier-terser": "7.2.0",
    "husky": "9.1.7",
    "ignore": "7.0.5",
    "jasmine-core": "6.0.1",
    "jasmine-expect": "5.0.0",
    "jsdom": "28.1.0",
    "jszip": "3.10.1",
    "jump.js": "1.0.2",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "karma-mocha-reporter": "2.2.5",
    "lint-staged": "16.2.7",
    "marked": "17.0.3",
    "marked-gfm-heading-id": "4.1.3",
    "marked-highlight": "2.2.3",
    "netlify-cms-proxy-server": "1.3.24",
    "ng-packagr": "21.1.0",
    "node-static": "0.7.11",
    "nodemon": "3.1.14",
    "npm-run-all": "4.1.5",
    "parse-url": "10.0.3",
    "patch-package": "8.0.1",
    "playwright": "1.58.2",
    "postcss-cli": "11.0.1",
    "prettier": "3.8.1",
    "prismjs": "1.30.0",
    "rimraf": "6.1.2",
    "rxjs": "7.8.2",
    "semantic-release": "25.0.3",
    "storybook": "10.2.13",
    "storybook-addon-pseudo-states": "10.2.8",
    "stylelint": "17.2.0",
    "stylelint-config-recommended-scss": "17.0.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-plugin-license-header": "1.0.3",
    "ts-node": "10.9.2",
    "tsconfig-paths-webpack-plugin": "4.2.0",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "wait-port": "1.1.0",
    "xml-js": "1.6.11",
    "xmlbuilder": "15.1.1",
    "yaml": "2.8.2",
    "yargs": "18.0.0",
    "zone.js": "0.16.0"
  }
}
