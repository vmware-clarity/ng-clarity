/* To learn more about this file see: https://angular.io/config/tsconfig. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": ".",
    "declaration": false,
    "downlevelIteration": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "lib": ["es2020", "dom", "dom.iterable"],
    "module": "es2020",
    "moduleResolution": "node",
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "strict": false, // TURN BACK ON
    "target": "es2022",
    "useDefineForClassFields": false,
    "paths": {
      "@clr/angular": ["projects/angular/src/index.ts"],
      "@clr/angular/*": ["projects/angular/src/*"],
      "@clr/addons": ["projects/addons/index.ts"],
      "@clr/addons/*": ["projects/addons/*"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictTemplates": true,
    // Angular 17+ added strict type-checking of @HostBinding/@HostListener via
    // `typeCheckHostBindings`. Several legacy directives in the library (clrFocusOnViewInit,
    // ariaActiveDescendant, etc.) use untyped `host` bindings that fail this check under
    // CDK 20+. Disabling here preserves v15-v19 behavior on a patch release; remove and
    // fix each host binding type in a follow-up structural cleanup (out of scope for CDE-3098).
    "typeCheckHostBindings": false
  },
  "exclude": ["dist", "node_modules"]
}
